# Copier ce fichier en .env.local et remplir avec vos vraies valeurs

# === DATABASE NEON ===
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require

# === ADMIN CREDENTIALS (à changer en production!) ===
